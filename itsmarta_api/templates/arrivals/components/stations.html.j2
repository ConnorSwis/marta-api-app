<section
  id="stations"
  class="panel"
  hx-get="{{ request.state.domain }}{{ context.poll_url }}"
  hx-trigger="every 10s"
  hx-swap="outerHTML"
  hx-indicator="#global-indicator"
>
  <div class="arrivals-summary">
    <p class="arrivals-meta">{{ context.trains | length }} arrivals loaded at {{ context.loaded_at }}</p>
    <p class="arrivals-meta">
      {% if context.line %}Line: {{ context.line | upper }}{% else %}All lines{% endif %}
      {% if context.direction %} | {{ context.direction | upper }}{% endif %}
      {% if context.query %} | "{{ context.query }}"{% endif %}
    </p>
    {% if context.trains %}
    <div class="arrivals-summary-actions">
      <button
        type="button"
        id="arrivals-expand-all"
        class="btn btn-secondary btn-small arrivals-expand-all"
      >
        Expand all
      </button>
    </div>
    {% endif %}
  </div>

  {% if context.error %}
  <div class="error-banner">{{ context.error }}</div>
  {% endif %}

  {% if not context.trains %}
  <div class="empty-state">No arrivals found for the current filters.</div>
  {% else %}
  <div class="stations-grid-inner">
    {% for station, station_trains in context.trains | groupby('station') %}
    {% set sorted_trains = station_trains | sort(attribute='waiting_seconds') %}
    <details class="station-card station-dropdown" data-station-dropdown>
      <summary class="station-summary">
        <h3 class="station-title">{{ station | replace(' STATION', '') }}</h3>
        <span class="station-summary-caret" aria-hidden="true"></span>
      </summary>
      <ul class="train-list">
        {% for train in sorted_trains[:context.per_station] %}
        <li class="train-row">
          <span class="line-pill line-{{ train.line | lower }}">
            {{ train.direction[0] | upper }}
          </span>
          <span class="train-destination">{{ train.destination }}</span>
          <span class="train-wait">
            {% if train.real_time %}
            <img
              src="{{ url_for('static', path='images/real-time.png') }}"
              alt="Realtime update"
              class="train-realtime-icon"
            />
            {% endif %}
            {{ train.waiting_time }}
          </span>
        </li>
        {% endfor %}
      </ul>
    </details>
    {% endfor %}
  </div>
  {% endif %}
</section>
